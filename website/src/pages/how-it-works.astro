---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BrainTree from '../components/BrainTree.astro';
---

<Layout title="How It Works — Bravenger" description="Build a Brain. Power your agents. Measure alignment. See how the Company Brain works in three steps.">
  <Navbar />

  <!-- Page Hero -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[1.1] mb-6">
        Build a Brain.<br/>
        Power your agents.<br/>
        <span class="text-[var(--color-accent)]">Measure alignment.</span>
      </h1>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        One week from scattered positioning to a working system that grounds every team's output and catches drift before it reaches your prospects.
      </p>
    </div>
  </section>

  <!-- Step 1: Build Your Brain -->
  <section class="py-20 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto scroll-reveal">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[var(--color-accent)] flex items-center justify-center text-white font-bold">1</div>
            <div class="font-mono text-sm text-[var(--color-accent)]">Build your Brain</div>
          </div>
          <h2 class="text-3xl font-bold mb-4">One week. Fixed price. We extract your positioning, structure it into a Brain, and hand you a working system.</h2>
          <p class="text-[var(--color-text-muted)] text-lg mb-6 leading-relaxed">
            We interview your stakeholders, audit your existing content, and build your Company Brain: ICP, personas, use cases, positioning, messaging, governance rules, and discipline-specific agent guidelines. You go from scattered positioning to a working system in five business days.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">$10-15K one-time — less than one month of a freelance content strategist</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Built on Markdown + YAML — portable, version-controlled, yours</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Same architecture every time — proven, repeatable, durable</span>
            </div>
          </div>
        </div>
        <div>
          <BrainTree />
        </div>
      </div>
    </div>
  </section>

  <!-- Step 2: Power Your Agents -->
  <section class="py-20 px-6 border-t border-[var(--color-border)] bg-[var(--color-bg-card)]">
    <div class="max-w-6xl mx-auto scroll-reveal">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <div class="bg-[var(--color-bg-code)] rounded-xl p-6 border border-[var(--color-border)] font-mono text-sm">
            <div class="text-[var(--color-text-muted)] mb-3">// Marketing Agent output for Technical Founder</div>
            <div class="text-[var(--color-text)]">## Blog Intro: "Your Knowledge Doesn't Scale"</div>
            <div class="mt-2 text-[var(--color-text-muted)]">**Target Persona:** P-001 Technical Founder</div>
            <div class="text-[var(--color-text-muted)]">**VP Anchor:** VP6 — Survives the Founder</div>
            <div class="mt-3 text-[var(--color-text)]">You built this product. You know it better than</div>
            <div class="text-[var(--color-text)]">anyone. But you can't be on every sales call,</div>
            <div class="text-[var(--color-text)]">review every blog post, and onboard every new hire.</div>
            <div class="text-[var(--color-text)]">Your positioning lives in your head, and that makes</div>
            <div class="text-[var(--color-text)]">you the bottleneck.</div>
            <div class="mt-3 text-[var(--color-accent)]">### Source Citations</div>
            <div class="text-[var(--color-accent)]">- [Source: personas/persona-founder.md#pains]</div>
            <div class="text-[var(--color-accent)]">- [Source: core-positioning.md#strategic-narratives]</div>
            <div class="text-[var(--color-accent)]">- [Source: messaging-framework.md#vp6]</div>
            <div class="mt-3 text-[var(--color-success)]">### Drift Check: PASSED</div>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[var(--color-accent)] flex items-center justify-center text-white font-bold">2</div>
            <div class="font-mono text-sm text-[var(--color-accent)]">Power your agents</div>
          </div>
          <h2 class="text-3xl font-bold mb-4">Five disciplines. Every agent cites its sources. Every time.</h2>
          <p class="text-[var(--color-text-muted)] text-lg mb-6 leading-relaxed">
            Five discipline-specific agents — Marketing, Sales, PMM, Product, CS — each with strict governance rules. They read the Brain in a mandatory 10-step order, produce team-specific outputs, cite every claim, and pass drift checks before anything ships.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Agent-native architecture — YAML frontmatter, consistent schemas, citation rules</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Every output traced to Brain sources — no hallucinated facts</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Governed by AGENTS.md — visible, editable, auditable</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 3: Detect Drift -->
  <section class="py-20 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto scroll-reveal">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[var(--color-accent)] flex items-center justify-center text-white font-bold">3</div>
            <div class="font-mono text-sm text-[var(--color-accent)]">Detect drift</div>
          </div>
          <h2 class="text-3xl font-bold mb-4">Drift detection that makes alignment measurable for the first time.</h2>
          <p class="text-[var(--color-text-muted)] text-lg mb-6 leading-relaxed">
            The Brain establishes the baseline. Drift detection measures deviation. Every drift event surfaces as an actionable card — with the drifted text, the Brain section it violates, and severity scoring. Even without automated scanning, the Brain's structure makes drift visible.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Forbidden language flags — words we avoid per brand-vision.md</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Undocumented claims — pains or features not in the Brain</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded bg-[var(--color-success)]/10 flex items-center justify-center">
                <svg class="w-3 h-3 text-[var(--color-success)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              </div>
              <span class="text-sm">Status honesty — gaps documented, not hidden</span>
            </div>
          </div>
        </div>
        <div class="bg-[var(--color-bg-code)] rounded-xl p-6 border border-[var(--color-border)]">
          <div class="flex items-center justify-between mb-4">
            <div class="font-mono text-sm text-[var(--color-text-muted)]">Drift Inbox</div>
            <div class="flex items-center gap-2 text-xs font-mono">
              <span class="px-2 py-0.5 rounded bg-[var(--color-drift-red)]/10 text-[var(--color-drift-red)]">2 Critical</span>
              <span class="px-2 py-0.5 rounded bg-[var(--color-drift)]/10 text-[var(--color-drift)]">3 High</span>
              <span class="px-2 py-0.5 rounded bg-[var(--color-accent)]/10 text-[var(--color-accent)]">5 Medium</span>
            </div>
          </div>
          <div class="space-y-3">
            <div class="bg-[var(--color-bg)] rounded-lg p-4 border border-[var(--color-border)]">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-[var(--color-drift-red)]/10 text-[var(--color-drift-red)]">CRITICAL</span>
                <span class="text-xs text-[var(--color-text-muted)]">Sales</span>
              </div>
              <div class="text-sm mb-1">Outbound uses <span class="text-[var(--color-drift-red)]">"revolutionary"</span> — forbidden per brand-vision.md#words-we-avoid</div>
              <div class="text-xs text-[var(--color-accent)]">→ Replace with specific outcome language</div>
            </div>
            <div class="bg-[var(--color-bg)] rounded-lg p-4 border border-[var(--color-border)]">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-[var(--color-drift)]/10 text-[var(--color-drift)]">HIGH</span>
                <span class="text-xs text-[var(--color-text-muted)]">Marketing</span>
              </div>
              <div class="text-sm mb-1">Blog post cites <span class="text-[var(--color-drift)]">pain not in icp.md</span> — "data silos" is undocumented</div>
              <div class="text-xs text-[var(--color-accent)]">→ Add to icp.md or remove from content</div>
            </div>
            <div class="bg-[var(--color-bg)] rounded-lg p-4 border border-[var(--color-border)]">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-[var(--color-accent)]/10 text-[var(--color-accent)]">MEDIUM</span>
                <span class="text-xs text-[var(--color-text-muted)]">Product</span>
              </div>
              <div class="text-sm mb-1">Feature brief targets <span class="text-[var(--color-accent)]">P-003 First PMM</span> — should be P-002 Head of Marketing</div>
              <div class="text-xs text-[var(--color-accent)]">→ Update persona reference</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="py-20 px-6 border-t border-[var(--color-border)] bg-[var(--color-bg-card)]">
    <div class="max-w-6xl mx-auto scroll-reveal">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Built for the people who own alignment.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-[var(--color-bg)] rounded-xl p-8 border border-[var(--color-border)]">
          <div class="text-sm font-mono text-[var(--color-accent)] mb-3">Technical Founder</div>
          <p class="text-lg font-medium mb-4 leading-snug">
            "Your knowledge doesn't scale. A system does."
          </p>
          <p class="text-sm text-[var(--color-text-muted)]">
            You can't be on every sales call. The Brain captures your knowledge in a format that persists without you. Same architecture you'd build if you had the time. We do it in a week.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] rounded-xl p-8 border border-[var(--color-border)]">
          <div class="text-sm font-mono text-[var(--color-accent)] mb-3">Head of Marketing</div>
          <p class="text-lg font-medium mb-4 leading-snug">
            "You were hired to build marketing. You need a foundation first."
          </p>
          <p class="text-sm text-[var(--color-text-muted)]">
            You inherited a blog with 12 posts and a pitch deck from the seed round. The Brain gives you the foundation in one week — ICP, personas, messaging, and agent guidelines from day one.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] rounded-xl p-8 border border-[var(--color-border)]">
          <div class="text-sm font-mono text-[var(--color-accent)] mb-3">First PMM</div>
          <p class="text-lg font-medium mb-4 leading-snug">
            "Build the foundation in a week, not a quarter."
          </p>
          <p class="text-sm text-[var(--color-text-muted)]">
            You need to establish positioning, build competitive intel, and enable sales. The normal timeline is 3-6 months. You spend your first quarter using the system — not building it from scratch.
          </p>
        </div>
        <div class="bg-[var(--color-bg)] rounded-xl p-8 border border-[var(--color-border)]">
          <div class="text-sm font-mono text-[var(--color-accent)] mb-3">VP/Head of Product</div>
          <p class="text-lg font-medium mb-4 leading-snug">
            "Structured data, not marketing narratives."
          </p>
          <p class="text-sm text-[var(--color-text-muted)]">
            Personas with structured fields and product hooks. Use cases with status fields and documented gaps. Data you can use to make product decisions — not "Startup Steve" with a stock photo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Not a Wiki -->
  <section class="py-20 px-6 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-12">Not a wiki. Not a writing tool.<br/>Not a brand guide. <span class="text-[var(--color-accent)]">A Company Brain.</span></h2>

      <div class="grid md:grid-cols-2 gap-4 text-left max-w-2xl mx-auto">
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
            <svg class="w-5 h-5 text-[var(--color-drift-red)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>Wikis become graveyards of stale pages</span>
          </div>
          <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
            <svg class="w-5 h-5 text-[var(--color-drift-red)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>AI tools generate without context</span>
          </div>
          <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
            <svg class="w-5 h-5 text-[var(--color-drift-red)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            <span>Brand guides serve Marketing only</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[var(--color-success)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>5 disciplines, not just marketing</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[var(--color-success)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Use cases feed every team</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[var(--color-success)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span>Built in one week, not one quarter</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

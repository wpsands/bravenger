{
  "type": "object",
  "required": ["title", "version", "last_updated", "owner", "status"],
  "properties": {
    "title": { "type": "string" },
    "version": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "owner": { "type": "string" },
    "status": { "type": "string", "enum": ["production", "draft", "deprecated"] }
  }
}

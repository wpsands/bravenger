{
  "type": "object",
  "required": ["title", "use_case_id", "version", "last_updated", "status", "personas", "icp_pain", "connected_use_cases"],
  "properties": {
    "title": { "type": "string" },
    "use_case_id": { "type": "string", "pattern": "^UC-\\d{3}$" },
    "version": { "type": "string" },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": {
      "type": "string",
      "enum": ["fully-supported", "partially-supported", "manual-workaround", "on-roadmap", "not-supported"]
    },
    "personas": {
      "type": "object",
      "required": ["setup_by", "used_by", "evaluated_by"],
      "properties": {
        "setup_by": { "type": "string", "pattern": "^P-\\d{3}$" },
        "used_by": {
          "type": "array",
          "items": { "type": "string", "pattern": "^P-\\d{3}$" }
        },
        "evaluated_by": { "type": "string", "pattern": "^P-\\d{3}$" }
      }
    },
    "icp_pain": { "type": "string" },
    "current_alternative": { "type": "string" },
    "tools_involved": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proof": { "type": "string" },
    "connected_use_cases": {
      "type": "array",
      "items": { "type": "string", "pattern": "^UC-\\d{3}$" }
    }
  }
}
